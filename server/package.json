{
	"name": "server",
	"version": "0.0.1",
	"main": "dist/src/index.js",
	"types": "dist/src/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/src/index.d.ts",
			"import": "./dist/src/index.js"
		},
		"./client": {
			"types": "./dist/src/client.d.ts",
			"import": "./dist/src/client.js"
		}
	},
	"scripts": {
		"predev": "bun run db:generate && bun run db:migrate",
		"dev": "bun --watch run src/index.ts && tsc --watch",
		"build": "tsc -b",
		"preview": "bun ./dist/src/index.js",
		"start": "bun ./dist/src/index.js",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@hono/zod-validator": "^0.7.5",
		"drizzle-orm": "^0.44.5",
		"drizzle-zod": "^0.8.3",
		"postgres": "^3.4.7",
		"shared": "workspace:*"
	},
	"devDependencies": {
		"@types/bun": "^1.3.10",
		"drizzle-kit": "^0.31.4"
	}
}
